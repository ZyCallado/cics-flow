
rules_version = '2'
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model while providing a dedicated pathway for 
     * administrators. By utilizing a specific collection for administrator IDs, we ensure 
     * high-performance authorization checks without the overhead of deep document nesting.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin();

      // Rules for the personal downloads library subcollection
      match /downloads/{downloadId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /documents/{documentId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow update: if resource != null && (
        resource.data.uploaderId == request.auth.uid || 
        isAdmin() || 
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadCount', 'updatedAt']))
      );
      allow delete: if resource != null && (resource.data.uploaderId == request.auth.uid || isAdmin());
    }

    match /activityLogs/{activityLogId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false; 
      allow delete: if isAdmin();
    }
  }
}
