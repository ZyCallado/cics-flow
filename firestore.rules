rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model while providing a dedicated pathway for 
     * administrators. By utilizing a specific collection for administrator IDs, we ensure 
     * high-performance authorization checks without the overhead of deep document nesting.
     *
     * DATA STRUCTURE
     * - /users/{userId}: Private user profiles.
     * - /roles_admin/{adminId}: A lookup collection to verify administrative privileges.
     * - /documents/{documentId}: Shared or private document metadata.
     * - /activityLogs/{activityLogId}: Audit trail for system actions.
     *
     * KEY SECURITY DECISIONS
     * - Authorization Independence: We use denormalized fields (like uploaderId and userId) 
     *   directly on documents to avoid costly get() calls during security evaluation.
     * - Database-Based Access Control (DBAC): Administrative status is determined by the 
     *   existence of a document in the /roles_admin collection, rather than using Custom Claims.
     * - Prototyping Flexibility: Logic enforces "who" can access data and relational 
     *   integrity for ownership, but does not strictly validate the content schema.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user is registered in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Users can manage their own data; admins can view/manage all.
     * @path /users/{userId}
     * @allow (get) If request.auth.uid == userId or if user is an admin.
     * @deny (list) If a non-admin attempts to list all users.
     * @principle Restricts access to a user's own data tree or admin oversight.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for the admin role lookup collection. 
     * Users can read their own admin status. For prototyping, users can create their own admin record.
     * @path /roles_admin/{adminId}
     * @principle existence-based access control for administrative roles.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow list: if isAdmin();
      // Prototype-only: Allow users to promote themselves. In production, this would be isAdmin() only.
      allow create: if isSignedIn() && isOwner(adminId);
      allow update, delete: if isAdmin();
    }

    /**
     * @description Rules for document metadata. Access is granted to the uploader, people in the permissions list, or admins.
     * @path /documents/{documentId}
     * @allow (create) If authenticated and uploaderId matches the user's UID.
     * @deny (update) If user is not the uploader or an admin.
     * @principle Enforces document ownership and relational integrity via uploaderId.
     */
    match /documents/{documentId} {
      allow get: if isSignedIn() && (resource.data.uploaderId == request.auth.uid || (request.auth.uid in resource.data.permissions) || isAdmin());
      allow list: if isSignedIn(); // Queries must still filter by uploaderId or permissions list for non-admins.
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow update: if resource != null && (resource.data.uploaderId == request.auth.uid || isAdmin());
      allow delete: if resource != null && (resource.data.uploaderId == request.auth.uid || isAdmin());
    }

    /**
     * @description Rules for activity logs. Users can view their own logs; admins can view all for auditing.
     * @path /activityLogs/{activityLogId}
     * @allow (create) If the log's userId matches the authenticated user.
     * @deny (update) All updates; logs are meant to be immutable.
     * @principle Provides auditable logs with owner-only read access and admin oversight.
     */
    match /activityLogs/{activityLogId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn(); // Queries must filter by userId for non-admins.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false; 
      allow delete: if isAdmin();
    }
  }
}